PORT=3000

# Required in production to enable POST /api/cache/clear
ADMIN_TOKEN=change-me-to-a-long-random-string

# Comma-separated origins (use * only for local dev)
CORS_ORIGIN=http://localhost:3000

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_GLOBAL_MAX=120

# SQLite path (local dev). On Render use CACHE_MEMORY_ONLY=1 instead.
CACHE_DB_PATH=cache.db
CACHE_MEMORY_ONLY=

# Deezer country for charts / discover (default FR)
DEEZER_COUNTRY=FR

# Supabase — required for Vibes social API (/auth, /users, /feed, …)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
